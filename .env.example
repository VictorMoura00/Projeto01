# ============================================================================
# AdminCore — Environment Configuration
# ============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env real no Git.
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND (.NET 10 Web API)
# ─────────────────────────────────────────────────────────────────────────────

# Porta da API (padrão: 5000)
ASPNETCORE_HTTP_PORTS=5000

# Connection String do PostgreSQL
# Formato: Host=localhost;Port=5432;Database=admincore_dev;Username=...;Password=...
DATABASE_URL=Host=localhost;Port=5432;Database=admincore_dev;Username=postgres;Password=postgres

# JWT Configuration
# Use uma chave de pelo menos 32 caracteres em produção.
# Exemplo de geração: openssl rand -base64 32
JWT_KEY=dev-only-secret-key-min-32-changes-in-prod
JWT_ISSUER=AdminCore
JWT_AUDIENCE=AdminCoreClients
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=30

# CORS Origins (separados por vírgula)
CORS_ORIGINS=http://localhost:4200

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (Angular 21)
# ─────────────────────────────────────────────────────────────────────────────

# URL base da API
FRONTEND_API_URL=http://localhost:5000

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER / INFRAESTRUTURA
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (usado pelo docker-compose.dev.yml)
POSTGRES_DB=admincore_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────────────────────────
# OPENCODE / AI AGENTS (opcional)
# ─────────────────────────────────────────────────────────────────────────────

# Configurações específicas de agentes, se necessário
# OPENAI_API_KEY=sk-...
